<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="V4BankGroupingSuite">
    <test name="SmokeTests">
        <groups>
            <run>
                <include name="Smoke"/>
            </run>
        </groups>
        <classes>
            <class name="org.example.Ex3"/>
        </classes>
    </test>

    <test name="RegressionTests">
        <groups>
            <run>
                <include name="Regression"/>
            </run>
        </groups>
        <classes>
            <class name="org.example.Ex3"/>
        </classes>
    </test>
</suite>